# Laravel API Configuration
# Kopiere diese Datei zu .env.local und passe die Werte an

# Laravel API Base URL (ohne trailing slash)
NEXT_PUBLIC_LARAVEL_API_URL=http://localhost:8000/api/game

# Externer Auth-Server (Login/Register/Me)
NEXT_PUBLIC_AUTH_API_URL=http://127.0.0.1:4100

# Optional: Supabase (für Realtime Multiplayer - kann leer bleiben wenn nur MySQL)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Default Municipality (Slug der Gemeinde für Single-Player)
NEXT_PUBLIC_DEFAULT_MUNICIPALITY=zurich
